  "rerank": {
    "clamp": [
      -0.045,
      0.05
    ],
    "base_weights": {
      "corpus_decision": {
        "primary": 0.005,
        "drop": -0.04
      },
      "delivery_value": {
        "high": 0.005,
        "medium": 0.002,
        "low": -0.002
      },
      "safety_relevance": {
        "high": 0.004,
        "medium": 0.001
      },
      "chunk_role": {
        "noise": -0.04,
        "unknown": -0.01
      }
    },
    "confidence_weight": 0.0025,
    "hit_weights": {
      "role": {
        "per_hit": 0.005,
        "cap": 0.008
      },
      "facet": {
        "per_hit": 0.004,
        "cap": 0.016
      },
      "layer": {
        "per_hit": 0.003,
        "cap": 0.009
      },
      "stage": {
        "per_hit": 0.002,
        "cap": 0.006
